# Floworio API Environment Variables
# Copy this file to .env and fill in your values

# Server
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# AI Story Generation (at least one required for AI stories)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Social Media APIs
# TikTok — https://developers.tiktok.com/
TIKTOK_ACCESS_TOKEN=

# Instagram/Facebook — https://developers.facebook.com/
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# YouTube — https://console.cloud.google.com/
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# LinkedIn — https://www.linkedin.com/developers/
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# Database (optional — for production)
DATABASE_URL=postgresql://user:password@localhost:5432/floworio

# Redis (optional — for production job queue)
REDIS_URL=redis://localhost:6379
